{
  "name": "local-port-dashboard",
  "version": "1.0.0",
  "description": "A small desktop dashboard to view and kill local ports",
  "main": "main.js",
  "bin": {
    "local-port-dashboard": "./bin/cli.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron": "^28.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.localportdashboard.app",
    "productName": "Local Port Dashboard",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "files": [
    "main.js",
    "server.js",
    "public/**/*",
    "bin/**/*",
    "assets/**/*",
    "node_modules/**/*"
  ]
}
